# BlindBox System - Render 环境变量配置
# 复制此文件为 .env 并在 Render Dashboard 中设置对应值

# ============================================
# 应用配置 (自动生成，无需修改)
# ============================================
NODE_ENV=production
PORT=3000

# ============================================
# 数据库配置 (Render MySQL 自动生成)
# ============================================
# DB_HOST=xxx.render.com
# DB_PORT=3306
# DB_USERNAME=blindbox
# DB_PASSWORD=xxx
# DB_NAME=blindbox_db

# ============================================
# Redis 配置 (Render Redis 自动生成)
# ============================================
# REDIS_HOST=xxx.render.com
# REDIS_PORT=6379

# ============================================
# JWT 配置 (自动生成)
# ============================================
# JWT_SECRET=xxx
JWT_EXPIRES_IN=7d
# JWT_REFRESH_SECRET=xxx
JWT_REFRESH_EXPIRES_IN=30d

# ============================================
# 微信支付配置 (必须手动设置)
# ============================================
# WECHAT_APP_ID=your-app-id
# WECHAT_APP_SECRET=your-app-secret
# WECHAT_MCH_ID=your-mch-id
# WECHAT_MCH_KEY=your-mch-key
WECHAT_NOTIFY_URL=https://blindbox-api.onrender.com/api/payment/notify

# ============================================
# CORS 配置
# ============================================
CORS_ORIGIN=https://blindbox-web.onrender.com,https://blindbox-admin.onrender.com

# ============================================
# OSS 配置 (可选，默认本地存储)
# ============================================
OSS_TYPE=local
# OSS_ENDPOINT=
# OSS_ACCESS_KEY=
# OSS_SECRET_KEY=
# OSS_BUCKET=
# OSS_REGION=

# ============================================
# 前端环境变量
# ============================================
VITE_API_BASE_URL=https://blindbox-api.onrender.com/api
