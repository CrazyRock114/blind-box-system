# Vercel + Supabase 环境变量配置

# Supabase PostgreSQL 数据库连接字符串
# 格式: postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres
SUPABASE_DATABASE_URL=

# Upstash Redis REST API
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# JWT 密钥 (使用 openssl rand -base64 32 生成)
JWT_SECRET=
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=30d

# CORS 配置
CORS_ORIGIN=https://blind-box-deploy.vercel.app

# 微信支付配置 (后续填写)
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_MCH_ID=
WECHAT_MCH_KEY=
WECHAT_NOTIFY_URL=

# 存储配置
OSS_TYPE=local

# Node环境
NODE_ENV=production
